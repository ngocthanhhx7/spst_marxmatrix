{
  "name": "@marxmatrix/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-api.mjs",
    "dev:worker": "nest start --watch --entryFile worker",
    "build": "nest build",
    "lint": "eslint src test --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run src --passWithNoTests",
    "test:integration": "vitest run --passWithNoTests --dir test/integration",
    "test:e2e": "vitest run --passWithNoTests --dir test/e2e",
    "seed": "pnpm run build && node dist/identity/demo-seed.js",
    "start:worker": "node dist/worker.js"
  },
  "dependencies": {
    "@google/genai": "2.12.0",
    "@marxmatrix/contracts": "workspace:*",
    "@nestjs/common": "11.1.27",
    "@nestjs/config": "4.0.2",
    "@nestjs/core": "11.1.27",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/mongoose": "11.0.4",
    "@nestjs/platform-express": "11.1.27",
    "@nestjs/platform-socket.io": "11.1.27",
    "@nestjs/swagger": "11.4.6",
    "@nestjs/throttler": "6.5.0",
    "@nestjs/websockets": "11.1.27",
    "bcrypt": "6.0.0",
    "cookie-parser": "1.4.7",
    "express": "5.2.1",
    "helmet": "8.3.0",
    "mongodb": "7.2.0",
    "mongoose": "9.7.4",
    "nestjs-pino": "4.6.1",
    "pdfjs-dist": "5.4.296",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "socket.io": "4.8.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.24",
    "@nestjs/testing": "11.1.27",
    "@types/bcrypt": "5.0.2",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/supertest": "6.0.3",
    "socket.io-client": "4.8.3",
    "supertest": "7.2.2",
    "vitest": "4.1.10"
  }
}
