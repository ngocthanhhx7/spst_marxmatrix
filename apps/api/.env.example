# Required; secret: no; source: deployment/runtime configuration; valid local value: development.
NODE_ENV=development
# Required; secret: no; source: deployment/runtime configuration; valid local value: 3000.
PORT=3000
# Required; secret: no; source: deployed web origin; valid local value: http://localhost:5173.
FRONTEND_URL=http://localhost:5173
# Required; secret: no; source: deployed web origins; valid local value: http://localhost:5173.
CORS_ORIGINS=http://localhost:5173
# Required; secret: yes; source: local MongoDB or managed MongoDB connection settings; valid local value: mongodb://localhost:27017. This localhost sample is credential-free and safe; a managed URI is secret.
MONGODB_URI=mongodb://localhost:27017
# Required; secret: no; source: application database configuration; valid local value: marxmatrix.
MONGODB_DB_NAME=marxmatrix
# Required; secret: no; source: application storage configuration; valid local value: uploads.
GRIDFS_BUCKET_NAME=uploads
# Required; secret: yes; source: generated deployment secret; valid local value: local-access-secret-change-me.
JWT_ACCESS_SECRET=local-access-secret-change-me
# Required; secret: yes; source: generated deployment secret; valid local value: local-refresh-secret-change-me.
JWT_REFRESH_SECRET=local-refresh-secret-change-me
# Required; secret: no; source: authentication policy; valid local value: 15m.
JWT_ACCESS_TTL=15m
# Required; secret: no; source: authentication policy; valid local value: 7d.
JWT_REFRESH_TTL=7d
# Required; secret: no; source: authentication cookie policy; valid local value: marxmatrix_refresh.
AUTH_COOKIE_NAME=marxmatrix_refresh
# Required; secret: no; source: HTTPS deployment policy; valid local value: false.
COOKIE_SECURE=false
# Required; secret: no; source: AI adapter selection; valid local value: mock.
AI_PROVIDER=mock
# Optional; secret: yes; source: Google AI Studio or Google Cloud; valid local value: leave blank when AI_PROVIDER=mock.
GEMINI_API_KEY=
# Optional; secret: no; source: Gemini model configuration; valid local value: gemini-2.5-flash.
GEMINI_GENERATION_MODEL=gemini-2.5-flash
# Optional; secret: no; source: Gemini model configuration; valid local value: gemini-embedding-001.
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Required; secret: no; source: AI resilience policy; valid local value: 15000.
AI_REQUEST_TIMEOUT_MS=15000
# Required; secret: no; source: AI resilience policy; valid local value: 2.
AI_MAX_RETRIES=2
# Required; secret: no; source: document upload policy; valid local value: 20.
DOCUMENT_MAX_SIZE_MB=20
# Required; secret: no; source: document upload policy; valid local value: application/pdf.
DOCUMENT_ALLOWED_MIME_TYPES=application/pdf
# Required; secret: no; source: rate-limit policy; valid local value: 60000.
RATE_LIMIT_TTL_MS=60000
# Required; secret: no; source: rate-limit policy; valid local value: 100.
RATE_LIMIT_MAX=100
# Required; secret: no; source: observability policy; valid local value: info.
LOG_LEVEL=info
# Required; secret: no; source: explicit local/demo runtime choice; valid local value: true.
DEMO_MODE=true
# Required; secret: no; source: authentication cookie policy; valid local value: lax.
AUTH_COOKIE_SAME_SITE=lax
# Required; secret: no; source: authentication cookie policy; valid local value: 604800000.
JWT_REFRESH_MAX_AGE_MS=604800000
RAG_VECTOR_PROVIDER=local
